// This is your Prisma schema file for LinkFlow AI
// Learn more: https://pris.ly/d/prisma-schema
// Run: npx prisma db push  (to sync with Neon)
// Run: npx prisma generate (to regenerate the client)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// USER
// ============================================================
model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  name           String?
  avatarUrl      String?  @map("avatar_url")
  provider       String   @default("email")
  creditBalance  Int      @default(1)  @map("credit_balance")
  totalTasksRun  Int      @default(0)  @map("total_tasks_run")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  payments       Payment[]
  tasks          BacklinkTask[]

  // NextAuth fields
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

// ============================================================
// NEXTAUTH TABLES
// ============================================================
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// PAYMENT
// ============================================================
model Payment {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  creemCheckoutId  String?  @unique @map("creem_checkout_id")
  creemProductId   String?  @map("creem_product_id")
  amount           Decimal? @db.Decimal(10, 2)
  currency         String   @default("USD")
  creditsAdded     Int      @default(0) @map("credits_added")
  status           String   @default("pending") // pending | completed | refunded
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================
// PLATFORM
// ============================================================
model Platform {
  id              Int      @id @default(autoincrement())
  siteName        String   @map("site_name")
  baseUrl         String   @map("base_url")
  category        String   @default("Web2.0") // Web2.0 | Social | Forum | Blog
  domainAuthority Int      @default(0) @map("domain_authority")
  selectorConfig  Json     @default("{}") @map("selector_config")
  loginRequired   Boolean  @default(true) @map("login_required")
  isActive        Boolean  @default(true) @map("is_active")
  logoUrl         String?  @map("logo_url")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  tasks BacklinkTask[]

  @@map("platforms")
}

// ============================================================
// BACKLINK TASK
// ============================================================
model BacklinkTask {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  platformId     Int?      @map("platform_id")

  // User input
  targetUrl      String    @map("target_url")
  anchorText     String    @map("anchor_text")
  articleContent String?   @map("article_content") @db.Text
  platformType   String    @default("Web2.0") @map("platform_type")

  // Status machine
  // pending → processing → success
  //                      ↘ failed
  //                      ↘ need_2fa → pending (after user action)
  status         String    @default("pending")
  retryCount     Int       @default(0) @map("retry_count")
  errorMessage   String?   @map("error_message") @db.Text

  // 2FA human-in-loop
  twofaCode      String?   @map("twofa_code")
  twofaPrompt    String?   @map("twofa_prompt")

  // Results
  screenshotUrl  String?   @map("screenshot_url")
  liveLinkUrl    String?   @map("live_link_url")

  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deadline       DateTime  @default(dbgenerated("(now() + '48:00:00'::interval)")) @map("deadline") @db.Timestamptz
  startedAt      DateTime? @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform Platform? @relation(fields: [platformId], references: [id])

  @@index([status])
  @@index([userId])
  @@index([deadline])
  @@map("backlink_tasks")
}



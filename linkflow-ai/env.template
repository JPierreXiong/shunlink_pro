# ============================================================
# LinkFlow AI — Combined Environment Variables Template
# ============================================================
# STEP 1: Copy this file → rename to .env
#         Windows:  copy env.template .env
#         Mac/Linux: cp env.template .env
# STEP 2: Fill in every value
# STEP 3: Run start.bat (Windows) or ./start.sh (Mac/Linux)
#
# The .env file is in .gitignore — your secrets stay local.
# ============================================================

# ── Database (Neon PostgreSQL) ────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
# CRITICAL: URL must end with ?sslmode=require (Neon enforces SSL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Prisma needs a direct (non-pooled) connection for migrations
# For Neon: use the "Direct connection" string from the dashboard
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── NextAuth (Web Authentication) ────────────────────────────
# Generate secret at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=replace-with-32-char-random-string
NEXTAUTH_URL=http://localhost:3000

# ── GitHub OAuth ─────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Homepage URL:  http://localhost:3000
# Callback URL:  http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# ── Google OAuth (optional) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ── Cloudinary (Screenshot Storage) ──────────────────────────
# Get from: https://cloudinary.com → Dashboard → copy the full URL line
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Resend (Email) ────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Creem (Payments) ──────────────────────────────────────────
# Get from: https://creem.io → Settings → API
CREEM_API_KEY=creem_xxxxxxxxxxxxxxxxxxxx
CREEM_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Product IDs — find in Creem dashboard → Products → copy the ID
CREEM_PRODUCT_10_CREDITS=prod_xxxxxxxxxxxxxxxxxxxx
CREEM_PRODUCT_25_CREDITS=prod_xxxxxxxxxxxxxxxxxxxx

# ── Prisma Direct URL ─────────────────────────────────────────
# Public App URL ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Worker Settings ───────────────────────────────────────────
HEADLESS=true
POLL_INTERVAL_SECONDS=10
MAX_RETRIES=3
WORKER_LOG_LEVEL=INFO
